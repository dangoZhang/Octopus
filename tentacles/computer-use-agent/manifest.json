{
  "$schema": "../tentacle.schema.json",
  "schema_version": "0.0.1",
  "id": "computer-use-agent",
  "name": "Computer Use Tentacle",
  "description": "LLM-guided local UI work through MCP, shell, screenshots, URLs, and desktop probes.",
  "brain": {
    "kind": "llm",
    "model": null,
    "prompt": "Translate observation or execution Needs into MCP, local UI, shell, or URL actions. Prefer visible, reversible steps and compact evidence.",
    "feedback_contract": "Return status, visible evidence, commands or MCP calls used, and unresolved user-visible risk."
  },
  "skills": [
    {
      "id": "computer-use",
      "description": "Observe and operate a local desktop environment.",
      "needs": ["observe", "execute", "verify"]
    }
  ],
  "tools": [
    {
      "id": "mcp",
      "description": "Call an MCP tool through a client adapter.",
      "input": "server id, tool id, JSON args",
      "output": "MCP call result",
      "permission": {
        "provider": "octopus",
        "scope": "tool:computer-use-agent",
        "permissions": ["tool:mcp"],
        "reason": "external tool bridge"
      },
      "implementation": { "kind": "mcp", "entrypoint": "tools/mcp.sh" }
    },
    {
      "id": "bash",
      "description": "Write and run a local shell script.",
      "input": "script on stdin",
      "output": "script output and stored script path",
      "permission": {
        "provider": "octopus",
        "scope": "tool:computer-use-agent",
        "permissions": ["tool:execute"],
        "reason": "local command execution"
      },
      "implementation": { "kind": "shell", "entrypoint": "tools/bash.sh" }
    },
    {
      "id": "screenshot",
      "description": "Capture the current screen.",
      "input": "output path",
      "output": "image file path",
      "permission": {
        "provider": "octopus",
        "scope": "tool:computer-use-agent",
        "permissions": ["tool:observe"],
        "reason": "screen capture"
      },
      "implementation": { "kind": "shell", "entrypoint": "tools/screenshot.sh" }
    },
    {
      "id": "open_url",
      "description": "Open a URL in the local desktop.",
      "input": "URL",
      "output": "open status",
      "permission": {
        "provider": "octopus",
        "scope": "tool:computer-use-agent",
        "permissions": ["tool:ui"],
        "reason": "user-visible desktop action"
      },
      "implementation": { "kind": "shell", "entrypoint": "tools/open_url.sh" }
    },
    {
      "id": "browser_status",
      "description": "Inspect local browser availability and current tab metadata when OS permissions allow it.",
      "input": "none",
      "output": "JSON browser availability, active tabs, opener, and notes",
      "permission": {
        "provider": "octopus",
        "scope": "tool:computer-use-agent",
        "permissions": ["tool:observe"],
        "reason": "browser tab metadata"
      },
      "implementation": { "kind": "shell", "entrypoint": "tools/browser_status.sh" }
    },
    {
      "id": "describe_screen",
      "description": "Return lightweight desktop context.",
      "input": "none",
      "output": "OS and process hints",
      "implementation": { "kind": "shell", "entrypoint": "tools/describe_screen.sh" }
    }
  ],
  "evolution": {
    "editable": ["manifest.json", "brain.prompt", "tools/*", "adapters/*"],
    "surfaces": [
      {
        "id": "brain_prompt",
        "description": "Tool-side UI planning prompt and feedback contract.",
        "targets": ["brain.prompt", "brain.feedback_contract"]
      },
      {
        "id": "tool_meta",
        "description": "Desktop tool descriptions, inputs, outputs, and call contracts.",
        "targets": ["tools[].description", "tools[].input", "tools[].output", "tools[].permission", "tools[].implementation.contract"]
      },
      {
        "id": "runtime_code",
        "description": "Editable UI, MCP, shell, native, browser, or remote adapters.",
        "targets": ["tools/*", "tools[].implementation.kind", "tools[].implementation.entrypoint"]
      },
      {
        "id": "evolution_policy",
        "description": "Checks and constraints that keep user-visible actions controlled.",
        "targets": ["evolution.checks", "evolution.constraints", "evolution.surfaces"]
      }
    ],
    "checks": [
      "tools/describe_screen.sh",
      "tools/browser_status.sh | python3 -m json.tool > /dev/null"
    ],
    "constraints": ["Ask for user-visible actions only when the product flow grants it."]
  }
}
