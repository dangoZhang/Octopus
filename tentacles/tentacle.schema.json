{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dangoZhang/Octopus/tentacles/tentacle.schema.json",
  "title": "Octopus Tentacle Manifest",
  "type": "object",
  "required": ["schema_version", "id", "name", "description", "brain", "skills", "tools", "evolution"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "type": "string" },
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "brain": {
      "description": "Tool-side intelligence. The clean brain emits Need; this brain plans how the tentacle feeds it.",
      "type": "object",
      "required": ["kind", "prompt"],
      "properties": {
        "kind": { "type": "string" },
        "model": { "type": ["string", "null"] },
        "prompt": { "type": "string" },
        "feedback_contract": { "type": "string" }
      },
      "additionalProperties": false
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "needs"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "needs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "tools": {
      "description": "Tool metadata plus code implementation pointers. These are harness-owned and evolvable.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "input", "output", "implementation"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "input": { "type": "string" },
          "output": { "type": "string" },
          "permission": {
            "description": "Optional runtime grant required before this tool can execute.",
            "type": "object",
            "required": ["provider", "scope", "permissions"],
            "properties": {
              "provider": { "type": "string" },
              "scope": { "type": "string" },
              "permissions": { "type": "array", "items": { "type": "string" } },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          },
          "implementation": {
            "description": "Runtime adapter, current code entrypoint, and optional call contract. kind can be shell, mcp, python, rust, node, wasm, http, native, static-html, or a custom adapter.",
            "type": "object",
            "required": ["kind", "entrypoint"],
            "properties": {
              "kind": { "type": "string" },
              "entrypoint": { "type": "string" },
              "contract": {
                "description": "Use octopus-json-v1 for stdin JSON tool calls; omit for legacy entrypoints.",
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "evolution": {
      "type": "object",
      "required": ["editable", "surfaces", "checks", "constraints"],
      "properties": {
        "editable": { "type": "array", "items": { "type": "string" } },
        "surfaces": {
          "description": "Named harness surfaces the tentacle may evolve: brain prompt, tool metadata, runtime code, and policy.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description", "targets"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "targets": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "checks": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
