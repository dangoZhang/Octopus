        "description": "Use the local Codex CLI login/API-key context to prepare a repository maintenance report.",
        "implementation": { "kind": "shell", "entrypoint": "tentacles/repo-maintainer/tools/codex_maintain.sh", "contract": "stdio-argv-v1" }
      },
      {
